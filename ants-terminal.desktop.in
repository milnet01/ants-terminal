[Desktop Entry]
Name=Ants Terminal
Comment=A modern terminal with themes, image support, and more
# Replace @INSTALL_DIR@ with the absolute path to the checked-out repo,
# e.g. /home/username/projects/ants-terminal — see README § Install.
Exec=@INSTALL_DIR@/launch.sh
Icon=ants-terminal
Terminal=false
Type=Application
Categories=Utility;TerminalEmulator;
Keywords=terminal;chat;ants;
StartupWMClass=ants-terminal
