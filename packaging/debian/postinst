#!/bin/sh
# postinst — refresh desktop DB + hicolor icon cache so the installed
# .desktop entry shows up in menus without requiring a session restart.
# Matches Debian Policy §9.11 (desktop-file-utils) + Fedora/openSUSE
# packaging guidelines. Errors are non-fatal (|| true) because failure
# to refresh the cache should not block install on minimal systems
# where the helper binaries are optional.

set -e

case "$1" in
    configure)
        if command -v update-desktop-database >/dev/null 2>&1; then
            update-desktop-database -q /usr/share/applications || true
        fi
        if command -v gtk-update-icon-cache >/dev/null 2>&1; then
            gtk-update-icon-cache -q /usr/share/icons/hicolor || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
